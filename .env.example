# Database -- consumed by the application and by docker-compose.
DATABASE_URL=postgresql+asyncpg://fx:devpass@localhost:5433/fx_engine
POSTGRES_PASSWORD=devpass

# Rate provider (https://exchangeratesapi.io free tier).
RATE_API_KEY=your-exchangeratesapi-key-here

# Shared secret required for POST /admin/rates/refresh when ENV=production.
ADMIN_TOKEN=local-dev-admin-token

# Environment: development | test | production.
# Test-fixture endpoints (POST /customers, POST /customers/{id}/credit)
# are disabled when ENV=production. The admin endpoint requires
# X-Admin-Token in production and is open elsewhere.
ENV=development
